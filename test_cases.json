{
  "bev_extraction": {
    "description": "Test cases for POST /api/v1/mobius/layer5/extract/events",
    "cases": [
      {
        "name": "TC-BEV-01: Happy path — 3 CONFIRMED episodes of same type promote to 1 BEv",
        "seed": {
          "episodes": [
            {"episode_id": "EP-T01", "episode_type": "FRAUD_SEQUENCE", "status": "CONFIRMED", "first_seen": "2025-01-01T00:00:00", "last_seen": "2025-01-02T00:00:00"},
            {"episode_id": "EP-T02", "episode_type": "FRAUD_SEQUENCE", "status": "CONFIRMED", "first_seen": "2025-01-03T00:00:00", "last_seen": "2025-01-04T00:00:00"},
            {"episode_id": "EP-T03", "episode_type": "FRAUD_SEQUENCE", "status": "CONFIRMED", "first_seen": "2025-01-05T00:00:00", "last_seen": "2025-01-06T00:00:00"}
          ]
        },
        "request": {"graph_name": "test_graph", "min_episode_count": 1},
        "expected": {
          "promoted": 1,
          "skipped": 0,
          "bev_archetype": "FRAUDULENT_COORDINATION",
          "recurrence_count": 3,
          "first_seen": "2025-01-01T00:00:00",
          "last_seen": "2025-01-06T00:00:00"
        },
        "why": "3 confirmed FRAUD_SEQUENCE episodes must map to exactly 1 FRAUDULENT_COORDINATION BEv node"
      },
      {
        "name": "TC-BEV-02: PENDING episodes must be excluded",
        "seed": {
          "episodes": [
            {"episode_id": "EP-T04", "episode_type": "FRAUD_SEQUENCE", "status": "CONFIRMED", "first_seen": "2025-01-01T00:00:00", "last_seen": "2025-01-02T00:00:00"},
            {"episode_id": "EP-T05", "episode_type": "FRAUD_SEQUENCE", "status": "PENDING",   "first_seen": "2025-01-03T00:00:00", "last_seen": "2025-01-04T00:00:00"},
            {"episode_id": "EP-T06", "episode_type": "FRAUD_SEQUENCE", "status": "CANDIDATE", "first_seen": "2025-01-05T00:00:00", "last_seen": "2025-01-06T00:00:00"}
          ]
        },
        "request": {"graph_name": "test_graph", "min_episode_count": 1},
        "expected": {
          "promoted": 1,
          "bev_archetype": "FRAUDULENT_COORDINATION",
          "recurrence_count": 1,
          "note": "Only EP-T04 (CONFIRMED) contributes. EP-T05 (PENDING) and EP-T06 (CANDIDATE) ignored."
        },
        "why": "Only CONFIRMED status episodes are eligible for BEv promotion"
      },
      {
        "name": "TC-BEV-03: Multiple episode types create multiple BEv nodes",
        "seed": {
          "episodes": [
            {"episode_id": "EP-T07", "episode_type": "FRAUD_SEQUENCE",    "status": "CONFIRMED", "first_seen": "2025-01-01T00:00:00", "last_seen": "2025-01-02T00:00:00"},
            {"episode_id": "EP-T08", "episode_type": "WASH_TRADING",      "status": "CONFIRMED", "first_seen": "2025-01-03T00:00:00", "last_seen": "2025-01-04T00:00:00"},
            {"episode_id": "EP-T09", "episode_type": "DATA_EXFILTRATION", "status": "CONFIRMED", "first_seen": "2025-01-05T00:00:00", "last_seen": "2025-01-06T00:00:00"}
          ]
        },
        "request": {"graph_name": "test_graph", "min_episode_count": 1},
        "expected": {
          "promoted": 3,
          "archetypes": ["FRAUDULENT_COORDINATION", "CIRCULAR_VALUE_TRANSFER", "UNAUTHORIZED_DATA_FLOW"]
        },
        "why": "Each distinct episode type maps to its own BEv archetype node"
      },
      {
        "name": "TC-BEV-04: min_episode_count threshold — below threshold skipped",
        "seed": {
          "episodes": [
            {"episode_id": "EP-T10", "episode_type": "FRAUD_SEQUENCE", "status": "CONFIRMED", "first_seen": "2025-01-01T00:00:00", "last_seen": "2025-01-02T00:00:00"},
            {"episode_id": "EP-T11", "episode_type": "FRAUD_SEQUENCE", "status": "CONFIRMED", "first_seen": "2025-01-03T00:00:00", "last_seen": "2025-01-04T00:00:00"},
            {"episode_id": "EP-T12", "episode_type": "WASH_TRADING",   "status": "CONFIRMED", "first_seen": "2025-01-05T00:00:00", "last_seen": "2025-01-06T00:00:00"}
          ]
        },
        "request": {"graph_name": "test_graph", "min_episode_count": 3},
        "expected": {
          "promoted": 0,
          "skipped": 3,
          "note": "FRAUD_SEQUENCE has 2 (< 3), WASH_TRADING has 1 (< 3). Both skipped."
        },
        "why": "min_episode_count=3 means archetype needs at least 3 confirmed episodes to promote"
      },
      {
        "name": "TC-BEV-05: Exactly at threshold — promotes",
        "seed": {
          "episodes": [
            {"episode_id": "EP-T13", "episode_type": "FRAUD_SEQUENCE", "status": "CONFIRMED", "first_seen": "2025-01-01T00:00:00", "last_seen": "2025-01-02T00:00:00"},
            {"episode_id": "EP-T14", "episode_type": "FRAUD_SEQUENCE", "status": "CONFIRMED", "first_seen": "2025-01-03T00:00:00", "last_seen": "2025-01-04T00:00:00"},
            {"episode_id": "EP-T15", "episode_type": "FRAUD_SEQUENCE", "status": "CONFIRMED", "first_seen": "2025-01-05T00:00:00", "last_seen": "2025-01-06T00:00:00"}
          ]
        },
        "request": {"graph_name": "test_graph", "min_episode_count": 3},
        "expected": {
          "promoted": 1,
          "note": "Exactly 3 episodes, threshold is 3. Must promote."
        },
        "why": "Boundary condition: exactly at threshold must pass, not fail"
      },
      {
        "name": "TC-BEV-06: No episodes — empty result",
        "seed": {"episodes": []},
        "request": {"graph_name": "test_graph", "min_episode_count": 1},
        "expected": {"promoted": 0, "skipped": 0, "nodes": []},
        "why": "Empty input must return empty result, no crash"
      },
      {
        "name": "TC-BEV-07: All 5 episode types — all archetypes created",
        "seed": {
          "episodes": [
            {"episode_id": "EP-T16", "episode_type": "FRAUD_SEQUENCE",         "status": "CONFIRMED", "first_seen": "2025-01-01T00:00:00", "last_seen": "2025-01-01T00:00:00"},
            {"episode_id": "EP-T17", "episode_type": "COORDINATED_RATING",     "status": "CONFIRMED", "first_seen": "2025-01-02T00:00:00", "last_seen": "2025-01-02T00:00:00"},
            {"episode_id": "EP-T18", "episode_type": "WASH_TRADING",           "status": "CONFIRMED", "first_seen": "2025-01-03T00:00:00", "last_seen": "2025-01-03T00:00:00"},
            {"episode_id": "EP-T19", "episode_type": "DATA_EXFILTRATION",      "status": "CONFIRMED", "first_seen": "2025-01-04T00:00:00", "last_seen": "2025-01-04T00:00:00"},
            {"episode_id": "EP-T20", "episode_type": "SENSOR_FAILURE_PATTERN", "status": "CONFIRMED", "first_seen": "2025-01-05T00:00:00", "last_seen": "2025-01-05T00:00:00"}
          ]
        },
        "request": {"graph_name": "test_graph", "min_episode_count": 1},
        "expected": {
          "promoted": 5,
          "archetypes": [
            "FRAUDULENT_COORDINATION",
            "SYNTHETIC_RATING_EVENT",
            "CIRCULAR_VALUE_TRANSFER",
            "UNAUTHORIZED_DATA_FLOW",
            "CASCADING_INFRASTRUCTURE_FAILURE"
          ]
        },
        "why": "Full archetype mapping coverage — all 5 episode types must produce their correct archetype"
      }
    ]
  },

  "be_extraction": {
    "description": "Test cases for POST /api/v1/mobius/layer5/extract/entities",
    "cases": [
      {
        "name": "TC-BE-01: Happy path — all 4 criteria pass",
        "seed": {
          "entities": [
            {
              "entity_id": "ENT-T01", "canonical_id": "user_alice", "role": "INITIATOR",
              "identity_confidence": 0.95, "window_count": 5, "partition_count": 3, "episode_count": 4,
              "first_seen": "2025-01-01T00:00:00", "last_seen": "2025-01-20T00:00:00"
            }
          ]
        },
        "request": {"graph_name": "test_graph"},
        "expected": {
          "promoted": 1,
          "skipped": 0,
          "be_canonical_id": "user_alice",
          "role": "INITIATOR"
        },
        "why": "All 4 Mobius PDF criteria met: identity resolved (0.95>=0.8), role persists (5>=3 windows), survives partitions (3>=2), matters strategically (4>=2 episodes)"
      },
      {
        "name": "TC-BE-02: Fails confidence — not promoted",
        "seed": {
          "entities": [
            {
              "entity_id": "ENT-T02", "canonical_id": "user_anon", "role": "INITIATOR",
              "identity_confidence": 0.75, "window_count": 5, "partition_count": 3, "episode_count": 4,
              "first_seen": "2025-01-01T00:00:00", "last_seen": "2025-01-20T00:00:00"
            }
          ]
        },
        "request": {"graph_name": "test_graph"},
        "expected": {"promoted": 0, "skipped": 1, "note": "confidence=0.75 < threshold 0.8"},
        "why": "Unresolved identity (low confidence) must not be promoted to durable BE — Mobius PDF criterion 1"
      },
      {
        "name": "TC-BE-03: Fails window_count — not promoted",
        "seed": {
          "entities": [
            {
              "entity_id": "ENT-T03", "canonical_id": "user_temp", "role": "OBSERVER",
              "identity_confidence": 0.90, "window_count": 2, "partition_count": 3, "episode_count": 4,
              "first_seen": "2025-01-01T00:00:00", "last_seen": "2025-01-05T00:00:00"
            }
          ]
        },
        "request": {"graph_name": "test_graph"},
        "expected": {"promoted": 0, "skipped": 1, "note": "window_count=2 < threshold 3"},
        "why": "Role must persist across time windows (PDF: role persists). 2 windows is not enough."
      },
      {
        "name": "TC-BE-04: Fails partition_count — not promoted",
        "seed": {
          "entities": [
            {
              "entity_id": "ENT-T04", "canonical_id": "user_local", "role": "INTERMEDIARY",
              "identity_confidence": 0.90, "window_count": 4, "partition_count": 1, "episode_count": 4,
              "first_seen": "2025-01-01T00:00:00", "last_seen": "2025-01-10T00:00:00"
            }
          ]
        },
        "request": {"graph_name": "test_graph"},
        "expected": {"promoted": 0, "skipped": 1, "note": "partition_count=1 < threshold 2"},
        "why": "Participation must survive across partitions (PDF: participation pattern survives). Single partition = local noise."
      },
      {
        "name": "TC-BE-05: Fails episode_count — not promoted",
        "seed": {
          "entities": [
            {
              "entity_id": "ENT-T05", "canonical_id": "user_onetime", "role": "TARGET",
              "identity_confidence": 0.90, "window_count": 4, "partition_count": 3, "episode_count": 1,
              "first_seen": "2025-01-01T00:00:00", "last_seen": "2025-01-10T00:00:00"
            }
          ]
        },
        "request": {"graph_name": "test_graph"},
        "expected": {"promoted": 0, "skipped": 1, "note": "episode_count=1 < threshold 2"},
        "why": "Entity must matter strategically (PDF: entity matters strategically) — appearing in only 1 episode is not enough"
      },
      {
        "name": "TC-BE-06: Exactly at threshold on all 4 criteria — promotes",
        "seed": {
          "entities": [
            {
              "entity_id": "ENT-T06", "canonical_id": "user_boundary", "role": "INITIATOR",
              "identity_confidence": 0.8, "window_count": 3, "partition_count": 2, "episode_count": 2,
              "first_seen": "2025-01-01T00:00:00", "last_seen": "2025-01-10T00:00:00"
            }
          ]
        },
        "request": {"graph_name": "test_graph"},
        "expected": {"promoted": 1, "skipped": 0},
        "why": "Boundary condition: exactly at all 4 thresholds must promote, not skip"
      },
      {
        "name": "TC-BE-07: Mixed — some promote, some skip",
        "seed": {
          "entities": [
            {"entity_id": "ENT-T07", "canonical_id": "user_good",  "role": "INITIATOR",    "identity_confidence": 0.95, "window_count": 5, "partition_count": 3, "episode_count": 4, "first_seen": "2025-01-01T00:00:00", "last_seen": "2025-01-10T00:00:00"},
            {"entity_id": "ENT-T08", "canonical_id": "user_bad1",  "role": "INTERMEDIARY", "identity_confidence": 0.70, "window_count": 5, "partition_count": 3, "episode_count": 4, "first_seen": "2025-01-01T00:00:00", "last_seen": "2025-01-10T00:00:00"},
            {"entity_id": "ENT-T09", "canonical_id": "user_bad2",  "role": "TARGET",       "identity_confidence": 0.90, "window_count": 1, "partition_count": 3, "episode_count": 4, "first_seen": "2025-01-01T00:00:00", "last_seen": "2025-01-10T00:00:00"},
            {"entity_id": "ENT-T10", "canonical_id": "user_good2", "role": "OBSERVER",     "identity_confidence": 0.85, "window_count": 3, "partition_count": 2, "episode_count": 3, "first_seen": "2025-01-01T00:00:00", "last_seen": "2025-01-10T00:00:00"}
          ]
        },
        "request": {"graph_name": "test_graph"},
        "expected": {
          "promoted": 2,
          "skipped": 2,
          "promoted_ids": ["user_good", "user_good2"],
          "skipped_reason": {"user_bad1": "confidence=0.70 < 0.8", "user_bad2": "window_count=1 < 3"}
        },
        "why": "Real-world mix: good entities promote, low-quality ones skip"
      }
    ]
  },

  "bp_extraction": {
    "description": "Test cases for POST /api/v1/mobius/layer5/extract/processes",
    "cases": [
      {
        "name": "TC-BP-01: Happy path — stable pattern with 6 episodes promotes",
        "seed": {
          "sequences": [
            {"seq_id": "SEQ-T01", "pattern_signature": "FAN_OUT->TRIANGLE->CHAIN", "steps": ["FAN_OUT", "TRIANGLE", "CHAIN"], "episode_count": 3, "first_seen": "2025-01-01T00:00:00", "last_seen": "2025-01-10T00:00:00"},
            {"seq_id": "SEQ-T02", "pattern_signature": "FAN_OUT->TRIANGLE->CHAIN", "steps": ["FAN_OUT", "TRIANGLE", "CHAIN"], "episode_count": 3, "first_seen": "2025-01-11T00:00:00", "last_seen": "2025-01-20T00:00:00"}
          ]
        },
        "request": {"graph_name": "test_graph", "min_episodes": 5, "transition_stability_threshold": 0.6},
        "expected": {
          "promoted": 1,
          "pattern_signature": "FAN_OUT->TRIANGLE->CHAIN",
          "episode_count": 6,
          "transition_probabilities": {"FAN_OUT->TRIANGLE": 1.0, "TRIANGLE->CHAIN": 1.0}
        },
        "why": "6 episodes (>=5), all transitions 100% stable (>=0.6). Must promote to BP."
      },
      {
        "name": "TC-BP-02: Too few episodes — not promoted",
        "seed": {
          "sequences": [
            {"seq_id": "SEQ-T03", "pattern_signature": "CHAIN->CHAIN", "steps": ["CHAIN", "CHAIN"], "episode_count": 2, "first_seen": "2025-01-01T00:00:00", "last_seen": "2025-01-05T00:00:00"}
          ]
        },
        "request": {"graph_name": "test_graph", "min_episodes": 5, "transition_stability_threshold": 0.6},
        "expected": {"promoted": 0, "skipped": 1, "note": "episode_count=2 < threshold 5"},
        "why": "Pattern seen only twice is not a stable business process — PDF: repeated workflow in >= N episodes"
      },
      {
        "name": "TC-BP-03: Unstable transitions — not promoted",
        "seed": {
          "sequences": [
            {"seq_id": "SEQ-T04", "pattern_signature": "FAN_OUT->X", "steps": ["FAN_OUT", "TRIANGLE"], "episode_count": 3, "first_seen": "2025-01-01T00:00:00", "last_seen": "2025-01-05T00:00:00"},
            {"seq_id": "SEQ-T05", "pattern_signature": "FAN_OUT->X", "steps": ["FAN_OUT", "CHAIN"],    "episode_count": 3, "first_seen": "2025-01-06T00:00:00", "last_seen": "2025-01-10T00:00:00"}
          ]
        },
        "request": {"graph_name": "test_graph", "min_episodes": 5, "transition_stability_threshold": 0.6},
        "expected": {
          "promoted": 0,
          "skipped": 2,
          "note": "FAN_OUT->TRIANGLE=0.5, FAN_OUT->CHAIN=0.5 — both below 0.6 threshold"
        },
        "why": "PDF: transition probabilities must stabilize. 50/50 split means pattern is not yet a process."
      },
      {
        "name": "TC-BP-04: Exactly at episode threshold — promotes",
        "seed": {
          "sequences": [
            {"seq_id": "SEQ-T06", "pattern_signature": "FAN_OUT->TRIANGLE", "steps": ["FAN_OUT", "TRIANGLE"], "episode_count": 3, "first_seen": "2025-01-01T00:00:00", "last_seen": "2025-01-10T00:00:00"},
            {"seq_id": "SEQ-T07", "pattern_signature": "FAN_OUT->TRIANGLE", "steps": ["FAN_OUT", "TRIANGLE"], "episode_count": 2, "first_seen": "2025-01-11T00:00:00", "last_seen": "2025-01-20T00:00:00"}
          ]
        },
        "request": {"graph_name": "test_graph", "min_episodes": 5, "transition_stability_threshold": 0.6},
        "expected": {
          "promoted": 1,
          "episode_count": 5,
          "transition_probabilities": {"FAN_OUT->TRIANGLE": 1.0}
        },
        "why": "Boundary condition: exactly 5 episodes at threshold=5 must promote"
      },
      {
        "name": "TC-BP-05: Multiple patterns — only stable ones promote",
        "seed": {
          "sequences": [
            {"seq_id": "SEQ-T08", "pattern_signature": "FAN_OUT->TRIANGLE->CHAIN", "steps": ["FAN_OUT", "TRIANGLE", "CHAIN"], "episode_count": 3, "first_seen": "2025-01-01T00:00:00", "last_seen": "2025-01-10T00:00:00"},
            {"seq_id": "SEQ-T09", "pattern_signature": "FAN_OUT->TRIANGLE->CHAIN", "steps": ["FAN_OUT", "TRIANGLE", "CHAIN"], "episode_count": 3, "first_seen": "2025-01-11T00:00:00", "last_seen": "2025-01-20T00:00:00"},
            {"seq_id": "SEQ-T10", "pattern_signature": "CHAIN->CHAIN",             "steps": ["CHAIN", "CHAIN"],              "episode_count": 2, "first_seen": "2025-01-01T00:00:00", "last_seen": "2025-01-05T00:00:00"}
          ]
        },
        "request": {"graph_name": "test_graph", "min_episodes": 5, "transition_stability_threshold": 0.6},
        "expected": {
          "promoted": 1,
          "skipped": 1,
          "promoted_pattern": "FAN_OUT->TRIANGLE->CHAIN",
          "skipped_pattern": "CHAIN->CHAIN"
        },
        "why": "Real-world mix: stable recurring pattern promotes, rare pattern skips"
      },
      {
        "name": "TC-BP-06: No sequences — empty result",
        "seed": {"sequences": []},
        "request": {"graph_name": "test_graph", "min_episodes": 5},
        "expected": {"promoted": 0, "skipped": 0, "nodes": []},
        "why": "Empty input must return empty result, no crash"
      }
    ]
  }
}
